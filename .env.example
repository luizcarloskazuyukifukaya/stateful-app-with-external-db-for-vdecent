# App Configuration
PORT=80

# Database Configuration
DATABASE_URL=postgres://user:password@db:5432/activitylog
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=activitylog

# Sidecar Backup Configuration
BACKUP_INTERVAL_MINS=5
BACKUP_RETENTION_COUNT=5
RESTORE_AUTH_TOKEN=change-me-to-a-secure-token
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id

# Google Credentials (path relative to sidecar directory or absolute)
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json
